{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hidden",
  "compatibility_date": "2026-06-06",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "env": {
    "staging": {
      "name": "hidden-staging",
      "workers_dev": true,
      "routes": [
        { "pattern": "staging.hidden.swlabs.cc", "custom_domain": true }
      ]
    }
  }
}
